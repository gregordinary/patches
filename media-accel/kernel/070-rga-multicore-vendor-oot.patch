+
+	u8 pixel_width = 1;
+	u8 yuv10 = 0;
+
+	/* enable r2y or y2r */
+	u8 win_r2y = 0;
+	u8 win_y2r = 0;
+
+	u8 rotate_mode = 0;
+	u8 xmirror = 0;
+	u8 ymirror = 0;
+
+	u32 stride = 0;
+	u32 uv_stride = 0;
