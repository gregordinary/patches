+
+enum rga_mm_flag {
+	/* It will identify whether the buffer is within 0 ~ 4G. */
+	RGA_MEM_UNDER_4G		= 1 << 0,
+	/* Logo enable IOMMU */
+	RGA_MEM_NEED_USE_IOMMU		= 1 << 1,
+	/* Flag this is a physical contiguous memory. */
