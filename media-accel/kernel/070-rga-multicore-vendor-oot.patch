+	u8 fading_r_value;
+	u8 fading_g_value;
+	u8 fading_b_value;
+
+	/* src global alpha value */
+	u8 src_a_global_val;
+	/* dst global alpha value */
+	u8 dst_a_global_val;
+
+	/* rop mode select 0 : rop2 1 : rop3 2 : rop4 */
+	u8 rop_mode;
+	/* rop2/3/4 code */
+	u16 rop_code;
+
+	/* (enum) color palette 0/1bpp, 1/2bpp 2/4bpp 3/8bpp*/
