+		dpw = 2;
+		dst_cbcr_swp = 1;
+		break;
+	case RGA_FORMAT_YVYU_420:
+		dst_format = 0xf;
+		dpw = 2;
+		break;
+	case RGA_FORMAT_UYVY_422:
