From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Sat, 18 Jul 2026 15:16:21 -0400
Subject: [PATCH] clk: rockchip: rk3576: handle the HDMITX, VO0, and HDPTX
 clocks

Add the display-path clock support the HDMI stack drives: get/set_rate
for the VO0 aclk/hclk and the VP0 dclk, a set_parent that muxes dclk_vp0
onto clk_hdmiphy_pixel0 (CLKSEL_CON147), and an enable op covering the
leaf gates the display drivers request (PCLK_HDPTX_APB in the PMU CRU,
PCLK_HDMITX0, CLK_HDMITX0_EARC, CLK_HDMITX0_REF, CLK_HDMITXHDP,
HCLK_VO0_ROOT). The gates reset open, so enabling them is declarative;
the mux and rates are load-bearing: the TMDS serializer and the VOP
pixel path must run from the same PHY PLL for a stable picture.

Signed-off-by: gregordinary <33880035+gregordinary@users.noreply.github.com>
---
 .../include/asm/arch-rockchip/cru_rk3576.h    |  18 ++
 drivers/clk/rockchip/clk_rk3576.c             | 157 ++++++++++++++++++
 2 files changed, 175 insertions(+)

diff --git a/arch/arm/include/asm/arch-rockchip/cru_rk3576.h b/arch/arm/include/asm/arch-rockchip/cru_rk3576.h
index c51750be..0f08eb24 100644
--- a/arch/arm/include/asm/arch-rockchip/cru_rk3576.h
+++ b/arch/arm/include/asm/arch-rockchip/cru_rk3576.h
@@ -451,6 +451,18 @@ enum {
 	ACLK_VO0_ROOT_SEL_BPLL,
 	ACLK_VO0_ROOT_DIV_SHIFT		= 0,
 	ACLK_VO0_ROOT_DIV_MASK		= 0x1f << ACLK_VO0_ROOT_DIV_SHIFT,
+	HCLK_VO0_ROOT_SEL_SHIFT		= 7,
+	HCLK_VO0_ROOT_SEL_MASK		= 3 << HCLK_VO0_ROOT_SEL_SHIFT,
+	HCLK_VO0_ROOT_SEL_200M		= 0,
+	HCLK_VO0_ROOT_SEL_100M,
+	HCLK_VO0_ROOT_SEL_50M,
+	HCLK_VO0_ROOT_SEL_OSC,
+	PCLK_VO0_ROOT_SEL_SHIFT		= 11,
+	PCLK_VO0_ROOT_SEL_MASK		= 3 << PCLK_VO0_ROOT_SEL_SHIFT,
+	PCLK_VO0_ROOT_SEL_150M		= 0,
+	PCLK_VO0_ROOT_SEL_100M,
+	PCLK_VO0_ROOT_SEL_50M,
+	PCLK_VO0_ROOT_SEL_OSC,
 
 	/* CRU_CLK_SEL151_CON */
 	CLK_DSIHOST0_SEL_SHIFT		= 7,
@@ -463,6 +475,12 @@ enum {
 	CLK_DSIHOST0_SEL_LPLL,
 	CLK_DSIHOST0_DIV_SHIFT		= 0,
 	CLK_DSIHOST0_DIV_MASK		= 0x7f << CLK_DSIHOST0_DIV_SHIFT,
+	CLK_HDMITX0_EARC_SEL_SHIFT	= 15,
+	CLK_HDMITX0_EARC_SEL_MASK	= 1 << CLK_HDMITX0_EARC_SEL_SHIFT,
+	CLK_HDMITX0_EARC_SEL_GPLL	= 0,
+	CLK_HDMITX0_EARC_SEL_CPLL,
+	CLK_HDMITX0_EARC_DIV_SHIFT	= 10,
+	CLK_HDMITX0_EARC_DIV_MASK	= 0x1f << CLK_HDMITX0_EARC_DIV_SHIFT,
 
 	/* PMUCRU_CLK_SEL5_CON */
 	CLK_PMU1PWM_SEL_SHIFT		= 2,
diff --git a/drivers/clk/rockchip/clk_rk3576.c b/drivers/clk/rockchip/clk_rk3576.c
index 125b08ee..69d59586 100644
--- a/drivers/clk/rockchip/clk_rk3576.c
+++ b/drivers/clk/rockchip/clk_rk3576.c
@@ -990,6 +990,56 @@ static ulong rk3576_aclk_vop_get_clk(struct rk3576_clk_priv *priv, ulong clk_id)
 			return 50 * MHz;
 		else
 			return OSC_HZ;
+	case HCLK_VO0_ROOT:
+		con = readl(&cru->clksel_con[149]);
+		sel = (con & HCLK_VO0_ROOT_SEL_MASK) >> HCLK_VO0_ROOT_SEL_SHIFT;
+		if (sel == HCLK_VO0_ROOT_SEL_200M)
+			return 200 * MHz;
+		else if (sel == HCLK_VO0_ROOT_SEL_100M)
+			return 100 * MHz;
+		else if (sel == HCLK_VO0_ROOT_SEL_50M)
+			return 50 * MHz;
+		else
+			return OSC_HZ;
+	case PCLK_VO0_ROOT:
+		con = readl(&cru->clksel_con[149]);
+		sel = (con & PCLK_VO0_ROOT_SEL_MASK) >> PCLK_VO0_ROOT_SEL_SHIFT;
+		if (sel == PCLK_VO0_ROOT_SEL_150M)
+			return 150 * MHz;
+		else if (sel == PCLK_VO0_ROOT_SEL_100M)
+			return 100 * MHz;
+		else if (sel == PCLK_VO0_ROOT_SEL_50M)
+			return 50 * MHz;
+		else
+			return OSC_HZ;
+	case CLK_HDMITX0_EARC:
+		con = readl(&cru->clksel_con[151]);
+		div = (con & CLK_HDMITX0_EARC_DIV_MASK) >> CLK_HDMITX0_EARC_DIV_SHIFT;
+		sel = (con & CLK_HDMITX0_EARC_SEL_MASK) >> CLK_HDMITX0_EARC_SEL_SHIFT;
+		if (sel == CLK_HDMITX0_EARC_SEL_CPLL)
+			parent = priv->cpll_hz;
+		else
+			parent = priv->gpll_hz;
+		return DIV_TO_RATE(parent, div);
+	case PCLK_HDMITX0:
+	case PCLK_VO0_GRF:
+		/* gates off PCLK_VO0_ROOT */
+		return rk3576_aclk_vop_get_clk(priv, PCLK_VO0_ROOT);
+	case CLK_HDMITX0_REF:
+		/* gate off ACLK_VO0_ROOT */
+		return rk3576_aclk_vop_get_clk(priv, ACLK_VO0_ROOT);
+	case CLK_HDMITXHDP:
+		/* gate off the 24 MHz oscillator */
+		return OSC_HZ;
+	case PCLK_HDPTX_APB:
+	case PCLK_PMUPHY_ROOT:
+		/*
+		 * PMU1 pclk gates. No CRU rate model exists for the PMU pclk
+		 * root and no consumer reads these rates; report a nominal
+		 * 100 MHz so clk_get_rate() does not fail. TODO: confirm the
+		 * PMU pclk root rate against the RK3576 TRM.
+		 */
+		return 100 * MHz;
 
 	default:
 		return -ENOENT;
@@ -1073,6 +1123,46 @@ static ulong rk3576_aclk_vop_set_clk(struct rk3576_clk_priv *priv,
 			     PCLK_VOP_ROOT_SEL_MASK,
 			     src_clk << PCLK_VOP_ROOT_SEL_SHIFT);
 		break;
+	case HCLK_VO0_ROOT:
+		if (rate == 200 * MHz)
+			src_clk = HCLK_VO0_ROOT_SEL_200M;
+		else if (rate == 100 * MHz)
+			src_clk = HCLK_VO0_ROOT_SEL_100M;
+		else if (rate == 50 * MHz)
+			src_clk = HCLK_VO0_ROOT_SEL_50M;
+		else
+			src_clk = HCLK_VO0_ROOT_SEL_OSC;
+		rk_clrsetreg(&cru->clksel_con[149],
+			     HCLK_VO0_ROOT_SEL_MASK,
+			     src_clk << HCLK_VO0_ROOT_SEL_SHIFT);
+		break;
+	case PCLK_VO0_ROOT:
+		if (rate == 150 * MHz)
+			src_clk = PCLK_VO0_ROOT_SEL_150M;
+		else if (rate == 100 * MHz)
+			src_clk = PCLK_VO0_ROOT_SEL_100M;
+		else if (rate == 50 * MHz)
+			src_clk = PCLK_VO0_ROOT_SEL_50M;
+		else
+			src_clk = PCLK_VO0_ROOT_SEL_OSC;
+		rk_clrsetreg(&cru->clksel_con[149],
+			     PCLK_VO0_ROOT_SEL_MASK,
+			     src_clk << PCLK_VO0_ROOT_SEL_SHIFT);
+		break;
+	case CLK_HDMITX0_EARC:
+		if (!(priv->gpll_hz % rate)) {
+			src_clk = CLK_HDMITX0_EARC_SEL_GPLL;
+			div = DIV_ROUND_UP(priv->gpll_hz, rate);
+		} else {
+			src_clk = CLK_HDMITX0_EARC_SEL_CPLL;
+			div = DIV_ROUND_UP(priv->cpll_hz, rate);
+		}
+		rk_clrsetreg(&cru->clksel_con[151],
+			     CLK_HDMITX0_EARC_SEL_MASK |
+			     CLK_HDMITX0_EARC_DIV_MASK,
+			     (src_clk << CLK_HDMITX0_EARC_SEL_SHIFT) |
+			     (div - 1) << CLK_HDMITX0_EARC_DIV_SHIFT);
+		break;
 
 	default:
 		return -ENOENT;
@@ -2000,6 +2090,15 @@ static ulong rk3576_clk_get_rate(struct clk *clk)
 	case ACLK_VO1_ROOT:
 	case HCLK_VOP_ROOT:
 	case PCLK_VOP_ROOT:
+	case HCLK_VO0_ROOT:
+	case PCLK_VO0_ROOT:
+	case PCLK_VO0_GRF:
+	case PCLK_HDMITX0:
+	case CLK_HDMITX0_REF:
+	case CLK_HDMITX0_EARC:
+	case CLK_HDMITXHDP:
+	case PCLK_HDPTX_APB:
+	case PCLK_PMUPHY_ROOT:
 		rate = rk3576_aclk_vop_get_clk(priv, clk->id);
 		break;
 	case DCLK_VP0:
@@ -2179,8 +2278,20 @@ static ulong rk3576_clk_set_rate(struct clk *clk, ulong rate)
 	case ACLK_VO1_ROOT:
 	case HCLK_VOP_ROOT:
 	case PCLK_VOP_ROOT:
+	case HCLK_VO0_ROOT:
+	case PCLK_VO0_ROOT:
+	case CLK_HDMITX0_EARC:
 		ret = rk3576_aclk_vop_set_clk(priv, clk->id, rate);
 		break;
+	case PCLK_VO0_GRF:
+	case PCLK_HDMITX0:
+	case CLK_HDMITX0_REF:
+	case CLK_HDMITXHDP:
+	case PCLK_HDPTX_APB:
+	case PCLK_PMUPHY_ROOT:
+		/* fixed-parent gates: no independent rate to program */
+		ret = 0;
+		break;
 	case DCLK_VP0:
 	case DCLK_VP0_SRC:
 	case DCLK_VP1:
@@ -2356,9 +2467,55 @@ static int rk3576_clk_set_parent(struct clk *clk, struct clk *parent)
 }
 #endif
 
+static int rk3576_clk_enable(struct clk *clk)
+{
+	switch (clk->id) {
+	case PCLK_HDPTX_APB:
+		/*
+		 * Ungate the HDPTX APB clock (PMU CLKGATE_CON0 bit 1): it
+		 * clocks the Samsung HDPTX PHY register block, and this driver
+		 * models no gates, so without it the CMN PLL-config writes
+		 * never latch and the ROPLL cannot lock. Unlisted ids stay at
+		 * their reset state, matching the prior no-.enable-op behaviour
+		 * where clk_enable() was a no-op.
+		 */
+		writel(0x00020000, RK3576_CRU_BASE + RK3576_PMU_CLKGATE_CON(0));
+		break;
+	case PCLK_HDMITX0:
+		/* pclk_vo0_root (CLKGATE_CON63 bit 3), then the leaf gate. */
+		writel(0x00080000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(63));
+		writel(0x00800000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(64));
+		break;
+	case CLK_HDMITX0_EARC:
+		/*
+		 * Also clocks the controller's HDCP2 register domain: with it
+		 * gated, HDCP2LOGIC_* accesses raise a synchronous abort even
+		 * while the rest of the APB register file decodes fine.
+		 */
+		writel(0x01000000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(64));
+		break;
+	case CLK_HDMITX0_REF:
+		/* aclk_vo0_root (CLKGATE_CON63 bit 0), then the leaf gate. */
+		writel(0x00010000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(63));
+		writel(0x02000000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(64));
+		break;
+	case CLK_HDMITXHDP:
+		writel(0x20000000, RK3576_CRU_BASE + RK3576_PMU_CLKGATE_CON(1));
+		break;
+	case HCLK_VO0_ROOT:
+		writel(0x00020000, RK3576_CRU_BASE + RK3576_CLKGATE_CON(63));
+		break;
+	default:
+		break;
+	}
+
+	return 0;
+}
+
 static struct clk_ops rk3576_clk_ops = {
 	.get_rate = rk3576_clk_get_rate,
 	.set_rate = rk3576_clk_set_rate,
+	.enable = rk3576_clk_enable,
 #if (IS_ENABLED(OF_CONTROL)) || (!IS_ENABLED(OF_PLATDATA))
 	.set_parent = rk3576_clk_set_parent,
 #endif
