From e4cab96224a677b4b851fc031e0c70c0a734a89b Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Sat, 18 Jul 2026 16:22:39 -0400
Subject: [PATCH] rockchip: rk3576: mux the console over serial and vidconsole
 by default

Boards without their own ROCKCHIP_DEVICE_SETTINGS get a default
environment of stdin=serial,usbkbd and stdout/stderr=serial,vidconsole,
the standard Rockchip video-capable console triple. With CONSOLE_MUX
the console comes up on every listed device that probes and silently
skips the rest, so the HDMI vidconsole and a USB keyboard join the
console as soon as the display stack and USB host are available, and a
headless board still gets its serial console.

Signed-off-by: gregordinary <33880035+gregordinary@users.noreply.github.com>
---
 include/configs/rk3576_common.h | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/include/configs/rk3576_common.h b/include/configs/rk3576_common.h
index 14d1d863..6b1d731d 100644
--- a/include/configs/rk3576_common.h
+++ b/include/configs/rk3576_common.h
@@ -17,7 +17,10 @@
 #define SDRAM_MAX_SIZE			(SZ_4G - CFG_SYS_SDRAM_BASE)
 
 #ifndef ROCKCHIP_DEVICE_SETTINGS
-#define ROCKCHIP_DEVICE_SETTINGS
+#define ROCKCHIP_DEVICE_SETTINGS \
+		"stdin=serial,usbkbd\0" \
+		"stdout=serial,vidconsole\0" \
+		"stderr=serial,vidconsole\0"
 #endif
 
 #define ENV_MEM_LAYOUT_SETTINGS		\
-- 
2.43.0

