index 94f6a84a..95b44e80 100644
--- a/configs/generic-rk3576_defconfig
+++ b/configs/generic-rk3576_defconfig
@@ -41,6 +41,8 @@ CONFIG_MMC_SDHCI=y
 CONFIG_MMC_SDHCI_SDMA=y
 CONFIG_MMC_SDHCI_ROCKCHIP=y
 CONFIG_PHY_ROCKCHIP_INNO_USB2=y
+CONFIG_POWER_DOMAIN=y
+CONFIG_RK3576_POWER_DOMAIN=y
 CONFIG_BAUDRATE=1500000
 CONFIG_DEBUG_UART_SHIFT=2
 CONFIG_SYS_NS16550_MEM32=y
diff --git a/drivers/power/domain/Kconfig b/drivers/power/domain/Kconfig
index 935f282d..4c545429 100644
--- a/drivers/power/domain/Kconfig
+++ b/drivers/power/domain/Kconfig
@@ -133,6 +133,15 @@ config TI_OMAP_PRM_POWER_DOMAIN
 	  The driver is currently a stub to be able to probe devices that
 	  require this type of power domain device.
 
+config RK3576_POWER_DOMAIN
+	bool "Enable the Rockchip RK3576 power domain driver"
+	depends on POWER_DOMAIN && ARCH_ROCKCHIP
+	help
+	  Enable the PMU power-domain driver for the Rockchip RK3576. It
+	  ungates the SoC power domains referenced by <&power ...> phandles
+	  in the device tree -- notably VO0 and VOP for the HDMI display
+	  path. Only powering domains up is supported.
+
 config ZYNQMP_POWER_DOMAIN
 	bool "Enable the Xilinx ZynqMP Power domain driver"
 	depends on POWER_DOMAIN && ZYNQMP_FIRMWARE
diff --git a/drivers/power/domain/Makefile b/drivers/power/domain/Makefile
index b2c0bd8a..7bbb3d64 100644
--- a/drivers/power/domain/Makefile
+++ b/drivers/power/domain/Makefile
@@ -7,6 +7,7 @@ obj-$(CONFIG_$(PHASE_)POWER_DOMAIN) += power-domain-uclass.o
 obj-$(CONFIG_APPLE_PMGR_POWER_DOMAIN) += apple-pmgr.o
 obj-$(CONFIG_AGILEX5_PMGR_POWER_DOMAIN) += altr-pmgr-agilex5.o
 obj-$(CONFIG_BCM6328_POWER_DOMAIN) += bcm6328-power-domain.o
+obj-$(CONFIG_RK3576_POWER_DOMAIN) += rk3576-power-domain.o
 obj-$(CONFIG_IMX8_POWER_DOMAIN) += imx8-power-domain-legacy.o imx8-power-domain.o
