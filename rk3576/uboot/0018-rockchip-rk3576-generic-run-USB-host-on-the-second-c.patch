From 95288af22f99a600926e76d74bb444877180e343 Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Sat, 18 Jul 2026 17:54:28 -0400
Subject: [PATCH] rockchip: rk3576-generic: run USB host on the second
 controller

Enable drd1 as a fixed USB host with its full upstream phy set (u2phy1
plus the naneng combphy USB3 lane). This is the proven u-boot host path
on RK3576 - the in-tree boards all run host on drd1 and keep drd0 as
the otg/gadget port; drd0-as-host fails port resets on a real device
even with the PHY brought up like the kernel does, so the console's
storage and keyboard move to the drd1 port. On the EVB-derived boards
that is the USB 2.0 Type-A port, which also frees the USB 3.0 port for
the maskrom download cable - the two roles no longer share a connector.

VBUS on that port is switched by gpio0 PC7 on the EVB-derived boards: a
boot-on fixed regulator drives the pin and the dwc3 host glue enables
it through the controller's vbus-supply.

Signed-off-by: gregordinary <33880035+gregordinary@users.noreply.github.com>
---
 arch/arm/dts/rk3576-generic-u-boot.dtsi | 36 +++++++++++++++++++++++++
 configs/generic-rk3576_defconfig        |  1 +
 2 files changed, 37 insertions(+)

diff --git a/arch/arm/dts/rk3576-generic-u-boot.dtsi b/arch/arm/dts/rk3576-generic-u-boot.dtsi
index 0c2a0cde..b3b19647 100644
--- a/arch/arm/dts/rk3576-generic-u-boot.dtsi
+++ b/arch/arm/dts/rk3576-generic-u-boot.dtsi
@@ -86,3 +86,39 @@
 &hdptxphy {
 	status = "okay";
 };
+
+/*
+ * USB host on the second controller (drd1) - the upstream-proven u-boot
+ * host path on RK3576: the in-tree boards all run host on drd1 with the
+ * u2phy1 + naneng combphy pair, while drd0 stays the otg/gadget port.
+ * The EVB-derived boards wire drd1 to a USB 2.0 Type-A port whose VBUS
+ * is switched by gpio0 PC7; the boot-on fixed regulator drives that pin
+ * and the dwc3 host glue enables it as the controller's vbus-supply.
+ */
+/ {
+	vcc5v0_usb_host: regulator-vcc5v0-usb-host {
+		compatible = "regulator-fixed";
+		regulator-name = "vcc5v0_usb_host";
+		regulator-boot-on;
+		enable-active-high;
+		gpio = <&gpio0 RK_PC7 GPIO_ACTIVE_HIGH>;
+	};
+};
+
+&u2phy1 {
+	status = "okay";
+};
+
+&u2phy1_otg {
+	status = "okay";
+};
+
+&combphy1_psu {
+	status = "okay";
+};
+
+&usb_drd1_dwc3 {
+	dr_mode = "host";
+	vbus-supply = <&vcc5v0_usb_host>;
+	status = "okay";
+};
diff --git a/configs/generic-rk3576_defconfig b/configs/generic-rk3576_defconfig
index b0466e3c..9aef9348 100644
--- a/configs/generic-rk3576_defconfig
+++ b/configs/generic-rk3576_defconfig
@@ -43,6 +43,7 @@ CONFIG_MMC_SDHCI=y
 CONFIG_MMC_SDHCI_SDMA=y
 CONFIG_MMC_SDHCI_ROCKCHIP=y
 CONFIG_PHY_ROCKCHIP_INNO_USB2=y
+CONFIG_PHY_ROCKCHIP_NANENG_COMBOPHY=y
 CONFIG_POWER_DOMAIN=y
 CONFIG_RK3576_POWER_DOMAIN=y
 CONFIG_BAUDRATE=1500000
-- 
2.43.0

