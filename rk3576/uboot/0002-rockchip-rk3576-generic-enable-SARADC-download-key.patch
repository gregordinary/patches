From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Fri, 10 Jul 2026 16:40:34 -0400
Subject: [PATCH] rockchip: rk3576-generic: enable SARADC download key

Enable the SARADC driver and turn on the saradc node in the generic
control DTB so setup_boot_mode()'s weak rockchip_dnl_key_pressed() can
sample channel 1 at boot. A grounded download key (raw sample <= 30)
then drops the board into BootROM download mode, reproducing the vendor
loader's physical recovery-button trigger on mainline u-boot. A
self-contained fixed 1.8V vref lets the ADC probe without a PMIC; the
key check is raw-threshold based, so its exact value is immaterial.

Signed-off-by: gregordinary <33880035+gregordinary@users.noreply.github.com>
---
 arch/arm/dts/rk3576-generic-u-boot.dtsi | 22 ++++++++++++++++++++++
 configs/generic-rk3576_defconfig        |  4 +++-
 2 files changed, 25 insertions(+), 1 deletion(-)

diff --git a/arch/arm/dts/rk3576-generic-u-boot.dtsi b/arch/arm/dts/rk3576-generic-u-boot.dtsi
index 632fabb6..98edec7f 100644
--- a/arch/arm/dts/rk3576-generic-u-boot.dtsi
+++ b/arch/arm/dts/rk3576-generic-u-boot.dtsi
@@ -1,3 +1,25 @@
 // SPDX-License-Identifier: (GPL-2.0+ OR MIT)
 
 #include "rk3576-u-boot.dtsi"
+
+/ {
+	/*
+	 * Self-contained 1.8V reference for the SARADC so the download-key
+	 * check in setup_boot_mode() can sample channel 1 without a PMIC.
+	 * rockchip_dnl_key_pressed() compares the raw sample against a fixed
+	 * window, so the exact reference does not matter -- it only has to let
+	 * the ADC driver probe.
+	 */
+	vref_1v8: regulator-vref-1v8 {
+		compatible = "regulator-fixed";
+		regulator-name = "vref_1v8";
+		regulator-min-microvolt = <1800000>;
+		regulator-max-microvolt = <1800000>;
+		regulator-always-on;
+	};
+};
+
+&saradc {
+	vref-supply = <&vref_1v8>;
+	status = "okay";
+};
diff --git a/configs/generic-rk3576_defconfig b/configs/generic-rk3576_defconfig
index 5e256538..15022300 100644
--- a/configs/generic-rk3576_defconfig
+++ b/configs/generic-rk3576_defconfig
@@ -23,11 +23,13 @@ CONFIG_CMD_ROCKUSB=y
 CONFIG_CMD_USB_MASS_STORAGE=y
 # CONFIG_CMD_SETEXPR is not set
 CONFIG_CMD_RNG=y
+CONFIG_CMD_ADC=y
 # CONFIG_SPL_DOS_PARTITION is not set
 # CONFIG_OF_UPSTREAM is not set
 CONFIG_OF_SPL_REMOVE_PROPS="clock-names interrupt-parent assigned-clocks assigned-clock-rates assigned-clock-parents"
 CONFIG_NO_NET=y
-# CONFIG_ADC is not set
+CONFIG_ADC=y
+CONFIG_SARADC_ROCKCHIP=y
 # CONFIG_USB_FUNCTION_FASTBOOT is not set
 CONFIG_ROCKCHIP_GPIO=y
 CONFIG_SUPPORT_EMMC_RPMB=y
