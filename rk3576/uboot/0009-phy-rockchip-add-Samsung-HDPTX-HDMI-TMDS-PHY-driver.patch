+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Interface between the DW-HDMI-QP bridge and the Samsung HDPTX PHY.
+ *
+ * Copyright (c) 2021 Rockchip Electronics Co. Ltd.
+ */
+
+#ifndef _ROCKCHIP_HDPTX_PHY_H
+#define _ROCKCHIP_HDPTX_PHY_H
+
+/**
+ * struct rockchip_hdptx_phy_cfg - HDMI/TMDS link parameters.
+ * @rate: pixel clock in Hz.
+ * @color_depth: true for 10bpc deep color, false for 8bpc.
+ *
+ * The bridge passes this to generic_phy_configure() to set the link rate
+ * before bringing the PHY lanes up with generic_phy_power_on().
+ */
+struct rockchip_hdptx_phy_cfg {
+	unsigned long rate;
+	bool color_depth;
+};
+
+#endif /* _ROCKCHIP_HDPTX_PHY_H */
