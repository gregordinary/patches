+}
+
+/*
+ * PHY operations. The DW-HDMI-QP bridge sets the link rate through
+ * configure(), then brings the serializer lanes up with power_on() once the
+ * ROPLL is locked (the clock child runs the common/PLL configuration when the
+ * VOP sets the pixel-clock rate).
+ */
+
+static int rockchip_hdptx_phy_power_on(struct phy *phy)
+{
+	struct rockchip_hdptx_phy *hdptx = dev_get_priv(phy->dev);
+
+	if (!hdptx->bit_rate)
+		return -EINVAL;
+
+	return hdptx_ropll_tmds_mode_config(hdptx, hdptx->bit_rate);
+}
+
+static int rockchip_hdptx_phy_power_off(struct phy *phy)
+{
+	return 0;
+}
+
+static int rockchip_hdptx_phy_configure(struct phy *phy, void *params)
+{
+	struct rockchip_hdptx_phy *hdptx = dev_get_priv(phy->dev);
+	struct rockchip_hdptx_phy_cfg *cfg = params;
+
+	hdptx->color_depth = cfg->color_depth;
+	hdptx->bit_rate = cfg->color_depth ?
+		(cfg->rate / 100) * 5 / 4 : cfg->rate / 100;
+
+	return 0;
+}
+
+static const struct phy_ops rockchip_hdptx_phy_ops = {
+	.power_on = rockchip_hdptx_phy_power_on,
+	.power_off = rockchip_hdptx_phy_power_off,
+	.configure = rockchip_hdptx_phy_configure,
+};
+
+static int rockchip_hdptx_phy_probe(struct udevice *dev)
+{
+	struct rockchip_hdptx_phy *hdptx = dev_get_priv(dev);
+	struct udevice *syscon;
+	int ret;
+
+	hdptx->dev = dev;
+
+	hdptx->base = dev_read_addr_ptr(dev);
+	if (!hdptx->base)
+		return -ENOENT;
+
+	ret = uclass_get_device_by_phandle(UCLASS_SYSCON, dev, "rockchip,grf",
+					   &syscon);
+	if (ret)
+		return ret;
+
+	hdptx->grf = syscon_get_regmap(syscon);
+	if (IS_ERR(hdptx->grf)) {
+		ret = PTR_ERR(hdptx->grf);
+		dev_err(dev, "unable to find regmap: %d\n", ret);
+		return ret;
+	}
+
+	ret = reset_get_by_name(dev, "apb", &hdptx->apb_reset);
+	if (ret < 0) {
+		dev_err(dev, "failed to get apb reset: %d\n", ret);
+		return ret;
+	}
+
+	ret = reset_get_by_name(dev, "init", &hdptx->init_reset);
+	if (ret < 0) {
+		dev_err(dev, "failed to get init reset: %d\n", ret);
+		return ret;
+	}
+
+	ret = reset_get_by_name(dev, "cmn", &hdptx->cmn_reset);
+	if (ret < 0) {
+		dev_err(dev, "failed to get cmn reset: %d\n", ret);
+		return ret;
+	}
+
+	ret = reset_get_by_name(dev, "lane", &hdptx->lane_reset);
+	if (ret < 0) {
+		dev_err(dev, "failed to get lane reset: %d\n", ret);
+		return ret;
+	}
+
+	ret = clk_get_by_name(dev, "ref", &hdptx->ref_clk);
+	if (ret) {
+		dev_err(dev, "failed to get ref clock: %d\n", ret);
+		return ret;
+	}
+
+	ret = clk_get_by_name(dev, "apb", &hdptx->apb_clk);
+	if (ret) {
+		dev_err(dev, "failed to get apb clock: %d\n", ret);
+		return ret;
+	}
+
+	/*
+	 * Enable the reference and APB clocks before any register access or
+	 * PLL bring-up, as mainline does. The rk3576 CRU driver ungates
+	 * PCLK_HDPTX_APB on the apb enable; CLK_PHY_REF_SRC already muxes to
+	 * the 24 MHz oscillator the ROPLL divider math assumes.
+	 */
+	clk_enable(&hdptx->ref_clk);
+	clk_enable(&hdptx->apb_clk);
+
+	return 0;
+}
+
+/*
+ * Bind the pixel-clock child on the PHY's own OF node. The node carries
+ * #clock-cells = <0>, so a display controller referencing it as a clock
+ * parent (the VOP's pll_hdmiphy0) resolves to this UCLASS_CLK device.
+ *
+ * The child device name "hdmiphypll_clk0" is load-bearing: clk_rk3576.c's
+ * DCLK reparent (rk3576_dclk_vop_set_parent) selects the HDMI-PHY pixel leg
+ * of the DCLK_VPn mux only when the new parent's device name is exactly
+ * "hdmiphypll_clk0". A different name silently leaves DCLK on the CRU PLL
+ * leg, so the VOP would not track the PHY pixel clock.
+ */
+static int rockchip_hdptx_phy_bind(struct udevice *parent)
+{
+	int ret;
+
+	ret = device_bind_driver_to_node(parent, "clk_hdptx", "hdmiphypll_clk0",
+					 dev_ofnode(parent), NULL);
+	if (ret)
+		dev_err(parent, "clk_hdptx cannot bind its driver\n");
+
+	return ret;
+}
+
+static const struct udevice_id rockchip_hdptx_phy_ids[] = {
+	{ .compatible = "rockchip,rk3576-hdptx-phy" },
+	{ .compatible = "rockchip,rk3588-hdptx-phy" },
+	{}
+};
+
+U_BOOT_DRIVER(rockchip_hdptx_phy) = {
+	.name		= "rockchip_hdptx_phy",
+	.id		= UCLASS_PHY,
+	.of_match	= rockchip_hdptx_phy_ids,
+	.probe		= rockchip_hdptx_phy_probe,
+	.bind		= rockchip_hdptx_phy_bind,
+	.ops		= &rockchip_hdptx_phy_ops,
+	.priv_auto	= sizeof(struct rockchip_hdptx_phy),
+};
+
+static ulong hdptx_clk_get_rate(struct clk *clk)
+{
+	struct clk_hdptx *priv = dev_get_priv(clk->dev);
+
+	return priv->rate;
+}
+
+static ulong hdptx_clk_set_rate(struct clk *clk, ulong rate)
+{
+	struct clk_hdptx *priv = dev_get_priv(clk->dev);
+	struct rockchip_hdptx_phy *hdptx = dev_get_priv(clk->dev->parent);
+	u32 bit_rate;
+	int ret;
+
+	if (hdptx->color_depth && rate <= HDMI20_MAX_RATE)
+		bit_rate = (rate / 100) * 5 / 4;
+	else
+		bit_rate = rate / 100;
+
+	ret = hdptx_ropll_cmn_config(hdptx, bit_rate);
+	if (ret)
+		return ret;
+
+	priv->rate = rate;
+
+	return rate;
+}
+
+static const struct clk_ops hdptx_clk_ops = {
+	.get_rate	= hdptx_clk_get_rate,
+	.set_rate	= hdptx_clk_set_rate,
+};
+
+/*
+ * In order for other display interfaces to use hdmiphy as the source for
+ * dclk, hdmiphy registers a virtual clock driver.
+ */
+U_BOOT_DRIVER(clk_hdptx) = {
+	.name		= "clk_hdptx",
+	.id		= UCLASS_CLK,
+	.priv_auto	= sizeof(struct clk_hdptx),
+	.ops		= &hdptx_clk_ops,
+};
