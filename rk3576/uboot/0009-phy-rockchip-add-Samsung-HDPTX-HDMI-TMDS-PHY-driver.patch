From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Sat, 18 Jul 2026 15:16:36 -0400
Subject: [PATCH] phy: rockchip: add Samsung HDPTX HDMI TMDS PHY driver

TMDS-only driver for the RK3576 Samsung HDPTX combo PHY: ROPLL
configuration from the pixel rate, lane power-up, and hpd. The probe
claims and enables the ref and apb clocks by name, mirroring the
mainline clk_bulk set.

The PLL lock poll watches GRF_HDPTX_STATUS PLL_LOCK_DONE (bit 3): that
is the bit the RK3576 TRM start-up sequence names, and the one that
asserts once cmn_rstn releases. PHY_CLK_RDY (bit 2) comes up later in
STANDBY and is not a lock indicator. Lock takes about 1.06 ms on this
silicon against the TRM's sub-60 us claim, so the poll allows 10 ms.

Signed-off-by: gregordinary <33880035+gregordinary@users.noreply.github.com>
---
 drivers/phy/rockchip/Kconfig                  |   10 +
 drivers/phy/rockchip/Makefile                 |    1 +
 .../phy/rockchip/phy-rockchip-samsung-hdptx.c | 1324 +++++++++++++++++
 include/rockchip_hdptx_phy.h                  |   24 +
 4 files changed, 1359 insertions(+)
 create mode 100644 drivers/phy/rockchip/phy-rockchip-samsung-hdptx.c
 create mode 100644 include/rockchip_hdptx_phy.h

diff --git a/drivers/phy/rockchip/Kconfig b/drivers/phy/rockchip/Kconfig
index 80128335..6dd14106 100644
--- a/drivers/phy/rockchip/Kconfig
+++ b/drivers/phy/rockchip/Kconfig
@@ -40,6 +40,16 @@ config PHY_ROCKCHIP_PCIE
 	help
 	  Enable this to support the Rockchip PCIe PHY.
 
+config PHY_ROCKCHIP_SAMSUNG_HDPTX
+	bool "Rockchip Samsung HDPTX HDMI PHY Driver"
+	depends on ARCH_ROCKCHIP
+	select PHY
+	select LIB_RATIONAL
+	help
+	  Enable this to support HDMI/TMDS output on the Rockchip Samsung
+	  HDPTX combo PHY (RK3576/RK3588). The PHY also registers a virtual
+	  clock so the VOP can source its pixel clock from it.
+
 config PHY_ROCKCHIP_SNPS_PCIE3
 	bool "Rockchip Snps PCIe3 PHY Driver"
 	depends on PHY && ARCH_ROCKCHIP
