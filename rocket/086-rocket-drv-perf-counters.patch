From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: gregordinary <33880035+gregordinary@users.noreply.github.com>
Date: Tue, 30 Jun 2026 12:00:00 +0000
Subject: [PATCH] rocket: read-only DDMA register probe (debugfs, debug/RE
 only)

A disarmed-by-default, read-only debugfs probe of the core-0 DDMA register block
(core_base+0x8000) for hardware characterization. The SoC-hanging 0x2000 counter
path is NOT present (removed, not stubbed).

Review hardening (K4): the whole probe is compiled out unless the new
CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE debug Kconfig (default n) is set, so a
production build carries no debugfs surface or module params; rocket_ddma_probe
is now read-only via sysfs (0444 -- armed once at modprobe, not re-armable at
runtime); and power_hold's pm_runtime get/put refcount is serialized with a mutex
so racing debugfs writes cannot unbalance it.

Apply last (after clk/volt/keepattach).
---
 drivers/accel/rocket/Kconfig      |  14 ++
 drivers/accel/rocket/rocket_drv.c | 211 +++++++++++++++++++++++++++++-
 2 files changed, 224 insertions(+), 1 deletion(-)

diff --git a/drivers/accel/rocket/Kconfig b/drivers/accel/rocket/Kconfig
index 16465abe0660..fdc364f66611 100644
--- a/drivers/accel/rocket/Kconfig
+++ b/drivers/accel/rocket/Kconfig
@@ -22,3 +22,17 @@ config DRM_ACCEL_ROCKET
 
 	  To compile this driver as a module, choose M here: the
 	  module will be called rocket.
+
+config DRM_ACCEL_ROCKET_PERF_PROBE
+	bool "Rocket NPU DDMA register probe (debug/RE only)"
+	depends on DRM_ACCEL_ROCKET
+	depends on DEBUG_FS
+	help
+	  Build the read-only DDMA register probe (a debugfs interface under
+	  /sys/kernel/debug/rocket_perf) used to characterize the RK3588 NPU
+	  DDMA block during hardware reverse-engineering. It is disarmed by
+	  default at runtime (needs rocket_ddma_probe=1 at modprobe time) and
+	  performs only register reads, but it is a development tool with no
+	  use in production.
+
+	  If unsure, say N.
diff --git a/drivers/accel/rocket/rocket_drv.c b/drivers/accel/rocket/rocket_drv.c
index 62c73b9d5dc8..dc59cc8a65dd 100644
--- a/drivers/accel/rocket/rocket_drv.c
+++ b/drivers/accel/rocket/rocket_drv.c
@@ -13,6 +13,13 @@
 #include <linux/platform_device.h>
 #include <linux/pm_runtime.h>
 #include <linux/regulator/consumer.h>
+#if IS_ENABLED(CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE)
+#include <linux/debugfs.h>
+#include <linux/io.h>
+#include <linux/mutex.h>
+#include <linux/seq_file.h>
+#include <linux/uaccess.h>
+#endif
 
 #include "rocket_device.h"
 #include "rocket_drv.h"
@@ -458,17 +465,219 @@ static struct platform_driver rocket_driver = {
 	},
 };
 
+/*
+ * The DDMA register probe below is a hardware-RE / characterization tool, not a
+ * production feature. It is compiled out entirely unless
+ * CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE is set (a debug-only Kconfig, default n),
+ * so a shipping build carries neither the debugfs surface nor the module params.
+ */
+#if IS_ENABLED(CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE)
+
+/* ===== SAFE read-only DDMA register probe (debugfs) ===================== *
+ * History: the first cut of this probe read the BSP "amount" counter offsets in
+ * the 0x2000 page (core_base+0x2234 etc.). On rk3588 that page is NOT decoded
+ * (absent from the Mesa register map; Rockchip sets amount_top=NULL), and an
+ * MMIO READ there raised a bus abort that HARD-LOCKED the SoC. That path is
+ * removed entirely (a stub would be a re-armable footgun). The 0x2000
+ * counter page stays unmapped on rk3588.
+ *
+ * This probe reads only the DDMA block at core_base+0x8000, which IS a defined,
+ * decoded domain in the Mesa rocket register map (e.g. 0x8030 = DDMA
+ * CFG_STATUS). It is READ-ONLY (no writes -> cannot corrupt DDMA config; note
+ * 0x8010 = RD_WEIGHT_1), CORE-0 only, and DISARMED by default: it touches no
+ * hardware unless the module is loaded with rocket_ddma_probe=1. It reads the
+ * known CFG_STATUS first (each read its own seq_printf), so if even the 0x8000
+ * page fails to decode the abort lands on one identified read. Run with a
+ * hardware watchdog + serial console so a hang auto-recovers.
+ *
+ * Goal: characterize the rk3588 DDMA block, and check
+ * whether the legacy rk356x amount offsets (0x8034/38/3c) carry anything
+ * counter-like on rk3588.
+ */
+#define ROCKET_DDMA_PAGE_OFF	0x8000		/* DDMA domain base within a core window */
+#define ROCKET_DDMA_PAGE_SZ	0x1000
+/* page-relative offsets (absolute = 0x8000 + these; names per Mesa registers.xml) */
+#define DDMA_CFG_OUTSTANDING	0x000		/* 0x8000 */
+#define DDMA_RD_WEIGHT_0	0x004		/* 0x8004 */
+#define DDMA_WR_WEIGHT_0	0x008		/* 0x8008 */
+#define DDMA_CFG_ID_ERROR	0x00c		/* 0x800c */
+#define DDMA_RD_WEIGHT_1	0x010		/* 0x8010 (config -- never written) */
+#define DDMA_CFG_STATUS		0x030		/* 0x8030 -- KNOWN reg, read FIRST */
+#define DDMA_LEGACY_DT_WR	0x034		/* 0x8034 (rk356x old DT_WR_AMOUNT) */
+#define DDMA_LEGACY_DT_RD	0x038		/* 0x8038 (rk356x old DT_RD_AMOUNT) */
+#define DDMA_LEGACY_WT_RD	0x03c		/* 0x803c (rk356x old WT_RD_AMOUNT) */
+
+/*
+ * 0444 (read-only via sysfs): the probe is armed ONCE, at modprobe time
+ * (rocket_ddma_probe=1), and cannot be flipped back on at runtime -- so it is
+ * not a re-armable footgun on a live system.
+ */
+static bool rocket_ddma_probe;
+module_param(rocket_ddma_probe, bool, 0444);
+MODULE_PARM_DESC(rocket_ddma_probe,
+	"SAFE probe: 1 => /sys/kernel/debug/rocket_perf/ddma reads core-0 DDMA regs (READ-ONLY). Default 0 (disarmed); set at modprobe time only. Run with a hardware watchdog.");
+
+static struct dentry *rocket_perf_dir;
+static bool rocket_perf_held;
+/* Serializes power_hold writes so racing debugfs writers cannot unbalance the
+ * pm_runtime get/put refcount that rocket_perf_held tracks. */
+static DEFINE_MUTEX(rocket_perf_hold_lock);
+
+static int rocket_ddma_show(struct seq_file *m, void *unused)
+{
+	struct platform_device *pdev;
+	struct resource *res;
+	struct device *dev;
+	void __iomem *io;
+	int err;
+
+	if (!rocket_ddma_probe) {
+		seq_puts(m, "disarmed (read-only DDMA @0x8000 probe). Load with rocket_ddma_probe=1 to enable;\n");
+		seq_puts(m, "run a hardware watchdog + serial console first. The v1 0x2000 counter read was removed\n");
+		seq_puts(m, "(it hard-locked the SoC).\n");
+		return 0;
+	}
+	if (!rdev || rdev->num_cores < 1 || !rdev->cores[0].dev) {
+		seq_puts(m, "no device probed\n");
+		return 0;
+	}
+
+	dev = rdev->cores[0].dev;
+	pdev = to_platform_device(dev);
+	res = platform_get_resource_byname(pdev, IORESOURCE_MEM, "pc");
+	if (!res) {
+		seq_puts(m, "no \"pc\" resource\n");
+		return 0;
+	}
+
+	io = ioremap(res->start + ROCKET_DDMA_PAGE_OFF, ROCKET_DDMA_PAGE_SZ);
+	if (!io) {
+		seq_puts(m, "ioremap failed\n");
+		return 0;
+	}
+
+	err = pm_runtime_resume_and_get(dev);
+	if (err) {
+		seq_printf(m, "pm_runtime resume failed (%d)\n", err);
+		iounmap(io);
+		return 0;
+	}
+
+	seq_printf(m, "core0 DDMA @ pc_base+0x%x (phys 0x%llx), read-only:\n",
+		   ROCKET_DDMA_PAGE_OFF,
+		   (unsigned long long)res->start + ROCKET_DDMA_PAGE_OFF);
+
+	/* KNOWN register first: if the 0x8000 page decodes, this returns; if not,
+	 * the abort is on this single identified read. */
+	seq_printf(m, "  0x8030 CFG_STATUS      = 0x%08x\n", readl(io + DDMA_CFG_STATUS));
+	seq_printf(m, "  0x8000 CFG_OUTSTANDING = 0x%08x\n", readl(io + DDMA_CFG_OUTSTANDING));
+	seq_printf(m, "  0x8004 RD_WEIGHT_0     = 0x%08x\n", readl(io + DDMA_RD_WEIGHT_0));
+	seq_printf(m, "  0x8008 WR_WEIGHT_0     = 0x%08x\n", readl(io + DDMA_WR_WEIGHT_0));
+	seq_printf(m, "  0x800c CFG_ID_ERROR    = 0x%08x\n", readl(io + DDMA_CFG_ID_ERROR));
+	seq_printf(m, "  0x8010 RD_WEIGHT_1     = 0x%08x\n", readl(io + DDMA_RD_WEIGHT_1));
+	seq_printf(m, "  0x8034 legacy DT_WR    = 0x%08x\n", readl(io + DDMA_LEGACY_DT_WR));
+	seq_printf(m, "  0x8038 legacy DT_RD    = 0x%08x\n", readl(io + DDMA_LEGACY_DT_RD));
+	seq_printf(m, "  0x803c legacy WT_RD    = 0x%08x\n", readl(io + DDMA_LEGACY_WT_RD));
+
+	pm_runtime_mark_last_busy(dev);
+	pm_runtime_put_autosuspend(dev);
+	iounmap(io);
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(rocket_ddma);
+
+/*
+ * power_hold: pin all core power domains ON (pm_runtime_get_sync, no put) so the
+ * DDMA regs can be read before/after an externally-run job (e.g. to see whether
+ * the legacy offsets change with traffic); '0' releases. Keeping a domain
+ * powered is what an in-flight job does, so this is safe.
+ */
+static ssize_t rocket_perf_hold_write(struct file *file, const char __user *ubuf,
+				      size_t len, loff_t *off)
+{
+	unsigned int core;
+	char c = 0;
+	bool on;
+
+	if (!rdev)
+		return -ENODEV;
+	if (len == 0 || get_user(c, ubuf))
+		return -EFAULT;
+	on = (c != '0');
+
+	guard(mutex)(&rocket_perf_hold_lock);
+
+	if (on == rocket_perf_held)		/* idempotent: never double get/put */
+		return len;
+
+	for (core = 0; core < rdev->num_cores; core++) {
+		struct device *dev = rdev->cores[core].dev;
+
+		if (on)
+			pm_runtime_get_sync(dev);
+		else
+			pm_runtime_put(dev);
+	}
+	rocket_perf_held = on;
+	return len;
+}
+
+static const struct file_operations rocket_perf_hold_fops = {
+	.owner	= THIS_MODULE,
+	.open	= simple_open,
+	.write	= rocket_perf_hold_write,
+	.llseek	= default_llseek,
+};
+
+static void rocket_perf_init(void)
+{
+	rocket_perf_dir = debugfs_create_dir("rocket_perf", NULL);
+	debugfs_create_file("ddma", 0400, rocket_perf_dir, NULL, &rocket_ddma_fops);
+	debugfs_create_file("power_hold", 0200, rocket_perf_dir, NULL, &rocket_perf_hold_fops);
+}
+
+static void rocket_perf_fini(void)
+{
+	scoped_guard(mutex, &rocket_perf_hold_lock) {
+		if (rocket_perf_held && rdev) {
+			unsigned int core;
+
+			for (core = 0; core < rdev->num_cores; core++)
+				pm_runtime_put(rdev->cores[core].dev);
+			rocket_perf_held = false;
+		}
+	}
+	debugfs_remove_recursive(rocket_perf_dir);
+	rocket_perf_dir = NULL;
+}
+
+#else  /* !CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE */
+
+static inline void rocket_perf_init(void) { }
+static inline void rocket_perf_fini(void) { }
+
+#endif /* CONFIG_DRM_ACCEL_ROCKET_PERF_PROBE */
+
 static int __init rocket_register(void)
 {
+	int ret;
+
 	drm_dev = platform_device_register_simple("rknn", -1, NULL, 0);
 	if (IS_ERR(drm_dev))
 		return PTR_ERR(drm_dev);
 
-	return platform_driver_register(&rocket_driver);
+	ret = platform_driver_register(&rocket_driver);
+	if (ret)
+		return ret;
+
+	rocket_perf_init();
+	return 0;
 }
 
 static void __exit rocket_unregister(void)
 {
+	rocket_perf_fini();
+
 	platform_driver_unregister(&rocket_driver);
 
 	platform_device_unregister(drm_dev);
-- 
2.43.0

